<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Total Monthly Budget Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_background"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL MONTHLY BUDGET"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etMaxBudget"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Maximum budget"
                        android:inputType="numberDecimal"
                        android:background="@android:drawable/editbox_background"
                        android:padding="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etMinGoal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Minimum spending goal"
                        android:inputType="numberDecimal"
                        android:background="@android:drawable/editbox_background"
                        android:padding="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="4dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnSaveTotalBudget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp" />

                <!-- Progress bar for total spending against max budget -->
                <TextView
                    android:id="@+id/tvTotalSpent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Spent: R0.00"
                    android:textSize="14sp" />

                <ProgressBar
                    android:id="@+id/progressTotalBudget"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="4dp"
                    android:progressTint="@color/primary"
                    android:max="100" />

                <!-- Indicator for min goal -->
                <TextView
                    android:id="@+id/tvMinGoalStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="12sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Category Budgets Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Category Budgets"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAddCategoryBudget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Add"
                style="@style/Widget.Material3.Button.TextButton" />
        </LinearLayout>

        <!-- RecyclerView for category budgets -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategoryBudgets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Explanation text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Tip: Set a minimum goal to encourage spending (e.g., groceries) and a maximum to limit overspending."
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:padding="8dp"
            android:background="@color/primary_light" />

    </LinearLayout>
</ScrollView>